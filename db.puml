User }o--o| User : parent of

Assignment }o-left-|| Topic
Assignment ||-right-|| QuestionBank

Story ||-down-o{ ChildrenStoryLog
Story ||-down-o{ PreorderStory
Story ||--o{ StoryFeedback

Story ||--o{ StoryState : "1 to many"
Story ||--o{ StoryScript : "1 to many"
Story ||--o{ StoryIntent : "1 to many"
Story ||--o{ StoryEmbedding : "1 to many"
Story }o--|| GraphicAsset

' StoryState *-- ActorConfig : "contains in actors (jsonb)"
' StoryState *-- OnEnterAction : "contains in on_enter (jsonb)"
' StoryState *-- Transition : "contains in transitions (jsonb)"
' StoryScript *-- ScriptLine : "contains in lines (jsonb)"
ScriptLine }o--|| AudioAsset


Assignment ||-down-o{ AssignmentLog

BlackListStory ||--o{ Story

ParentPayment }o--|| User
ParentPayment }o--|| PaymentType

User ||--|| Role
User ||-right-|| BlackListStory
User ||--o{ TimeLimit
User ||--o{ StoryFeedback : "creates"
User ||--o{ Story : approves
User ||--o{ Story : creates
User ||--o{ AssignmentLog
User ||--o{ PreorderStory
User ||--o{ ChildrenStoryLog
User ||--o{ UserFeedback
User ||--o{ GameLog

Notification ||--o{ NotificationTarget : targets
Notification ||--o{ NotificationLog : logs
NotificationTarget }o--|| User
NotificationLog }o--|| User

Permission }o--|| Module
Permission }o--|| Action

RolePermission }o--|| Role
RolePermission }o--|| Permission

GameBank }o--|| GameType


@enduml
