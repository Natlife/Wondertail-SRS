User }o--o| User : parent of

StoryBank ||-down-o{ StoryScene : has
StoryScene }--o{ GraphicAsset : has
StoryScene }--o{ AudioAsset : has
StoryBank ||--o{ StoryFeedback : has

Assignment }o-left-|| Topic
Assignment ||-right-|| QuestionBank

StoryBank ||-down-o{ ChildrenStoryLog
StoryBank ||-down-o{ PreorderStory
StoryBank ||-down-o{ GraphicAsset
StoryBank ||-down-o{ AudioAsset


Assignment ||-down-o{ AssignmentLog

ParentPayment ||-right-o{ PaymentDescription : has
ParentPayment }o--|| User
ParentPayment }o--|| PaymentType

User ||--|| Role
User ||--o{ BlackListStory
User ||--o{ TimeLimit
User ||--o{ StoryBank : approves
User ||--o{ StoryBank : creates
User ||--o{ AssignmentLog
User ||--o{ PreorderStory
User ||--o{ ChildrenStoryLog
User ||--o{ StoryFeedback

Notification ||--o{ NotificationTarget : targets
Notification ||--o{ NotificationLog : logs
NotificationTarget }o--|| User
NotificationLog }o--|| User

Permission }o--|| Module
Permission }o--|| Action

RolePermission }o--|| Role
RolePermission }o--|| Permission

GameBank }o--|| GameType


@enduml

